<div id="terminal-overlay"
     class="fixed inset-0 z-50 bg-black flex flex-col hidden"
     data-terminal-target="overlay"
     role="dialog"
     aria-label="Terminal easter egg"
     aria-hidden="true">

  <div class="flex items-center justify-between px-4 py-2 border-b border-green-900 shrink-0">
    <span class="font-mono text-green-400 text-sm">
      visitor@torikafati-portfolio:~$
    </span>
    <div class="flex items-center gap-4">
      <span class="text-zinc-600 font-mono text-xs hidden sm:inline">
        press ~ or ESC to exit
      </span>
      <button data-action="click->terminal#toggle"
              class="text-zinc-500 hover:text-green-400 transition-colors font-mono text-lg leading-none"
              aria-label="Close terminal">
        &times;
      </button>
    </div>
  </div>

  <div id="xterm-container"
       data-terminal-target="container"
       class="flex-1 overflow-hidden p-1">
  </div>
</div>
