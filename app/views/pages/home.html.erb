<% content_for :title, "Home" %>

<%# Hero Section %>
<section class="min-h-screen flex items-center pt-20">
  <div class="max-w-5xl mx-auto px-6 py-20">
    <p class="font-mono text-green-400 text-sm mb-4 tracking-widest uppercase">Hello, world. I&rsquo;m</p>
    <h1 class="text-5xl md:text-7xl font-bold text-zinc-50 mb-4 leading-tight">
      <%= PORTFOLIO[:name] %>
    </h1>
    <h2 class="text-2xl md:text-3xl text-zinc-400 font-medium mb-8">
      <%= PORTFOLIO[:title] %>
    </h2>
    <p class="text-zinc-400 text-lg max-w-2xl mb-10 leading-relaxed">
      <%= PORTFOLIO[:bio] %>
    </p>
    <div class="flex flex-wrap gap-4">
      <%= link_to "View My Projects", projects_path,
          class: "bg-green-500 hover:bg-green-400 text-zinc-950 font-semibold px-6 py-3 rounded-lg transition-colors" %>
      <%= link_to "Get in Touch", contact_path,
          class: "border border-zinc-700 hover:border-green-500 text-zinc-300 hover:text-green-400 px-6 py-3 rounded-lg transition-colors" %>
    </div>
  </div>
</section>

<%# Featured Projects %>
<% if @featured_projects.any? %>
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <p class="font-mono text-green-400 text-xs mb-8 tracking-widest uppercase">Featured Work</p>
    <div class="grid md:grid-cols-3 gap-6">
      <%= render @featured_projects %>
    </div>
    <div class="text-center mt-10">
      <%= link_to "All Projects &rarr;".html_safe, projects_path,
          class: "text-green-400 hover:text-green-300 font-mono text-sm transition-colors" %>
    </div>
  </section>
<% end %>
